{
  "name": "react-native-sqlite-migrations",
  "version": "0.1.0",
  "description": "Laravel-style SQLite migrations for React Native with pre-destructive data migration hooks.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "rn-sqlite-migrations": "./bin/rn-sqlite-migrations.cjs"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "README.md",
    "docs",
    "examples",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test test/**/*.test.cjs",
    "test:coverage": "npm run build && rm -rf coverage && mkdir -p coverage/v8 && NODE_V8_COVERAGE=coverage/v8 node --experimental-test-coverage --test test/**/*.test.cjs",
    "migrations:create": "node ./bin/rn-sqlite-migrations.cjs create",
    "migrations:validate": "node ./bin/rn-sqlite-migrations.cjs validate",
    "migrations:manifest": "node ./bin/rn-sqlite-migrations.cjs manifest"
  },
  "keywords": [
    "react-native",
    "sqlite",
    "migration",
    "laravel"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
